# === Elasticsearch ===
ELASTIC_CLOUD_ID=
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_VERIFY_CERTS=true
ELASTIC_REQUEST_TIMEOUT=30

# === Index Names ===
KNOWLEDGE_BASE_INDEX=agentic-kb
INCIDENT_INDEX=agentic-incidents
SEARCH_TOP_K=5
MAX_AGENT_ITERATIONS=15
HYBRID_SEARCH_ENABLED=false

# === LLM (OpenAI-compatible) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=glm-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=

# === LLM Resilience ===
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=3

# === Kibana Agent Builder (optional) ===
KIBANA_URL=
KIBANA_API_KEY=
KIBANA_SPACE_ID=
ELASTIC_AGENT_ID=elastic-ai-agent

# === Runtime ===
TRACE_ENABLED=true
RUN_MODE=loop
LOOP_INTERVAL_SECONDS=3600
RETRY_DELAY=60
BOOTSTRAP_ON_START=true
LOAD_DEMO_DATA=false
